{
  "name": "get-suno-lyric",
  "version": "2.0.9",
  "description": "A Chrome browser extension that downloads synchronized lyrics from Suno.com in LRC or SRT formats.",
  "main": "index.js",
  "scripts": {
    "test": "pnpm test:release-notes && pnpm test:release-workflow && pnpm test:lyric-timing && pnpm test:source-archive && pnpm test:source-transition-docs",
    "test:release-notes": "node --test scripts/test-release-notes.mjs",
    "test:release-workflow": "node --test scripts/test-release-workflow.mjs",
    "test:lyric-timing": "node --test scripts/test-lyric-timing.mjs",
    "test:source-archive": "node --test scripts/test-source-archive.mjs",
    "test:source-transition-docs": "node --test scripts/test-source-transition-docs.mjs",
    "tsc": "tsc",
    "dev": "rspack build --watch --mode development",
    "build": "rspack build --mode production",
    "zip": "pnpm build && node scripts/zip.js",
    "release:notes": "node scripts/generate-release-notes.js",
    "source:archive": "node scripts/package-source-archive.js"
  },
  "keywords": [
    "browser",
    "extension",
    "chrome"
  ],
  "author": "zhanghe.dev",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "devDependencies": {
    "@rspack/cli": "^2.1.0",
    "@rspack/core": "^2.1.0",
    "@tailwindcss/postcss": "^4.3.1",
    "chrome-types": "^0.1.430",
    "css-loader": "^7.1.4",
    "postcss": "^8.5.15",
    "postcss-loader": "^8.2.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "archiver": "^8.0.0"
  }
}
